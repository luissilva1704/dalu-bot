# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# DynamoDB Table Names
DYNAMO_TABLE_SCHEDULES=dalu-schedules
DYNAMO_TABLE_BOOKINGS=dalu-bookings
DYNAMO_TABLE_CAPACITY=dalu-capacity

# Google Sheets webhook (optional - sends pre-reservation data after booking)
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
# GOOGLE_SHEETS_SECRET=your_secret_to_validate_webhook_requests

# OpenAI API Key (for nail analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Server
PORT=3000
NODE_ENV=development
